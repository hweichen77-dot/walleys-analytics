    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "date-fns": "^3.6.0",
    "dexie": "^3.2.7",
    "dexie-react-hooks": "^1.1.7",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.0"
  },
