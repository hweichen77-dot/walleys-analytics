{
  "name": "walleys-analytics",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --base ./",
    "build:tauri": "tsc -b && vite build",
    "lint": "eslint .",
